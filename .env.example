# Environment variables for Two-Tower Recommender System
# Copy this file to .env and fill in with actual values

# Backend API configuration
API_URL=http://localhost:8000

# Model and data paths (used by FastAPI)
MODEL_CHECKPOINT=/app/checkpoints/model_final.pt
FAISS_INDEX=/app/checkpoints/movie_embeddings.faiss
METADATA_PATH=/app/data/processed/metadata.json

# Python settings
PYTHONUNBUFFERED=1
